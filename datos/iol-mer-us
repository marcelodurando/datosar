<script>

    const Cotizacion = {
        Data: {
            EsAnonimo: 'True'.toLowerCase() === 'true',
            Paisfinal: 'Estados Unidos',
        },
        Element: {},
        Rutas: Object.freeze({
            Index: '/Mercado/Cotizaciones',
            AgregarFavorito: '/Mercado/AgregarFavorito',
            EliminarFavorito: '/Mercado/EliminarFavorito',
            FavoritoUser: '/User/ContenidoParaRegistrado/favorito'
        }),
        Function: {
            SetTitulo: (text) => {
                document.title = `${text} | invertirOnline.com`;
            },
            GetPaneles: (panelesHtml) => {
                let paneles = panelesHtml || '<option value="SP500"selected>SP500</option><option value="Dow Jones Industrial">Dow Jones Industrial</option><option value="Nasdaq 100">Nasdaq 100</option><option value="Otros">Otros</option>';
                return `
                    <div class="box-align-center mb20">
                        <label class="mr5 ml5 mb0">Cambiar Panel</label>
                        <select id="paneles" class="inputIOL mr10" data-tipo="listado">${paneles}</select>
                        <div>
                            <img id="listado" src="/Images/Common/menu.svg" class="fs20 iconlistado" data-toggle="tooltip" data-placement="top" alt="Listado">
                            <img id="treemap" src="/Images/Common/grid.svg" class="fs20 icontreemap colorvioleta" data-toggle="tooltip" data-placement="top" alt="Mapa de mercado">
                            <img src="/Images/Common/maximize-2.svg" class="fs18 pointer ml10 iconfullscreen" onclick="fullscreen()">
                            <img id="spinner" src="/Images/iol/Assets/loading.gif" class="ml10 hidden" alt="spinner">
                        </div>
                    </div>`;
            },
            OcultarBotonMapaChequesCauciones: () => {
                if ($('.instrumento.active').text().trim() === 'CHPD' || $('.instrumento.active').text().trim() === 'Cauciones')
                    $('#treemap').hide();
            },
            ReloadTable: (url, pais, instrumento, panel, mensajeAMostrar) => {
                var data = {
                    pais: pais,
                    instrumento: instrumento,
                    panel: panel,
                    actualizar: true
                };

                Cotizacion.Function.ShowSpinner();

                $.post(url,
                    data,
                    function (response) {
                        Cotizacion.Element.MainContainer.html(response);
                        Cotizacion.Function.HideSpinner();
                        Cotizacion.Function.SetTitulo($('#header-cotizaciones', response).text());

                        let text = `Encontrá todas las cotizaciones de ${$('#header-cotizaciones', response).html()} en InvertirOnline.com. Ingresá e informate.`;

                        $("meta[property='og\\:title']").attr("content", text);

                        if (mensajeAMostrar != null) {
                            toastr.success(mensajeAMostrar);
                        }
                    });
            },
            SetUrlSeo: (url) => {
                history.pushState(null, null, url.replace(/ /g, '-').toLowerCase());
            }
        },
        Init: () => {
            Cotizacion.Element.MainContainer = $('#cotizaciones-main');
            Cotizacion.Function.ShowSpinner = () => { $('#spinner').removeClass('hidden'); };
            Cotizacion.Function.HideSpinner = () => { $('#spinner').addClass('hidden'); };
            var pais = $('.pais .active a').data('nombre');
            var instrumento = $('.instrumento.active').data('nombre');
            clevertap.event.push("Cotizaciones", {
                "Mercado": pais, "Tipo activo": instrumento, "Simbolo": ""
            })
        }
    }
</script>


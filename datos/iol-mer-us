    function alterIcon($icon, isAlternate) {
        var className = $icon.attr('class');
        if (typeof className === "undefined")
            return;

        if (isAlternate)
            className = className.replace('-over', '');
        else
            className += '-over';

        $icon.attr('class', className);
    }

